# calsync environment configuration
#
# 1. Copy this file to .env: cp .env.example .env
# 2. Generate secret keys:    uv run python -m calsync.keygen
#    Paste the three CALSYNC_*_KEY / TOKEN values it prints into your .env.
# 3. Fill in Google OAuth credentials from Google Cloud Console
#    (https://console.cloud.google.com/apis/credentials):
#    - Create or pick a project, enable the Google Calendar API
#    - Configure the OAuth consent screen (External, scope: .../auth/calendar)
#    - Create an OAuth 2.0 Client ID (type: Web application)
#    - Authorized redirect URIs:
#        http://localhost:8000/oauth/callback         (dev)
#        https://calsync.menendez.com/oauth/callback  (prod, after deploy)
#    - Copy client ID and client secret below.

# Process environment ('dev' or 'prod')
CALSYNC_ENV=dev

# Public URL where this server is reachable (used as the OAuth redirect base
# and for registering Google watch channels). For dev, ngrok URL changes
# per restart; localhost:8000 only works for OAuth (Google permits it).
CALSYNC_PUBLIC_URL=http://localhost:8000

# Encrypts OAuth refresh tokens at rest in SQLite.
# Generate with: uv run python -m calsync.keygen
CALSYNC_FERNET_KEY=

# HMAC key that derives the deterministic, opaque calsync_mirror_key
# stamped on every Google mirror event. Loss forces a full mirror
# wipe-and-rebuild on recovery.
# Generate with: uv run python -m calsync.keygen
CALSYNC_MIRROR_HMAC_KEY=

# Required header on /admin/* endpoints + signing key for OAuth state tokens.
# Generate with: uv run python -m calsync.keygen
CALSYNC_ADMIN_TOKEN=

# Google OAuth client (from Cloud Console)
CALSYNC_GOOGLE_CLIENT_ID=
CALSYNC_GOOGLE_CLIENT_SECRET=

# SQLite database path. WAL files (.db-wal, .db-shm) appear alongside.
CALSYNC_DB_PATH=calsync-dev.db

# When true, log intended Google API mutations but do not perform them.
CALSYNC_DRY_RUN=false
